# Copy to .env and fill in. .env is gitignored.

# --- Splunk Enterprise connection ---
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_SCHEME=https
# Verify TLS cert. For local self-signed dev installs, set to "false".
SPLUNK_VERIFY_TLS=false

# Auth: either a bearer token (preferred) OR username+password.
# Create a token in Splunk Web: Settings > Tokens > New Token.
SPLUNK_TOKEN=
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=

# App namespace the Institutional Memory Agent writes to.
# Must match the installed Splunk app so the dashboard reads the same KV Store
# collections the CLI writes to.
SPLUNK_APP=ima
SPLUNK_OWNER=nobody

# --- KV Store collection names ---
IMA_KV_ANNOTATIONS=ima_annotations
IMA_KV_KNOWLEDGE=ima_knowledge
IMA_KV_ASSETS=ima_assets

# --- LLM provider for the extraction step ---
# Options: "ollama" (default, local), "splunk_hosted" (Foundation-Sec on Splunk Cloud), "stub" (no-op)
LLM_PROVIDER=ollama

# Local Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# Splunk-hosted Foundation-Sec-1.1-8B (used when LLM_PROVIDER=splunk_hosted).
# Wire this in if/when you migrate to Splunk Cloud Platform.
FOUNDATION_SEC_ENDPOINT=
FOUNDATION_SEC_API_KEY=
